{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "type"],
  "properties": {
    "name": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/name" },
    "type": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/type" },
    "description": {
      "oneOf": [
        { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/description" },
        {
          "type": "object",
          "description": "Description per base (base-ui vs radix).",
          "properties": {
            "base": { "type": "string" },
            "radix": { "type": "string" }
          },
          "required": ["base", "radix"],
          "additionalProperties": false
        }
      ]
    },
    "title": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/title" },
    "author": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/author" },
    "dependencies": {
      "oneOf": [
        { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/dependencies" },
        {
          "type": "object",
          "description": "NPM dependencies per base (base-ui vs radix).",
          "properties": {
            "base": { "type": "array", "items": { "type": "string" } },
            "radix": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      ]
    },
    "devDependencies": {
      "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/devDependencies"
    },
    "registryDependencies": {
      "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/registryDependencies"
    },
    "files": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/files" },
    "tailwind": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/tailwind" },
    "cssVars": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/cssVars" },
    "css": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/css" },
    "envVars": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/envVars" },
    "meta": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/meta" },
    "docs": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/docs" },
    "categories": {
      "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/categories"
    },
    "extends": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/extends" },
    "style": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/style" },
    "iconLibrary": {
      "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/iconLibrary"
    },
    "baseColor": {
      "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/baseColor"
    },
    "theme": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/theme" },
    "font": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/properties/font" }
  },
  "allOf": [
    { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/allOf/0" },
    { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/allOf/1" }
  ],
  "definitions": {
    "cssValue": { "$ref": "https://ui.shadcn.com/schema/registry-item.json#/definitions/cssValue" }
  }
}
