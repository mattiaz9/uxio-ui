[
  {
    "name": "semantic-colors",
    "type": "registry:style",
    "title": "Semantic Colors",
    "description": "Adds --success, --info, and --warning CSS variables for semantic color variants.",
    "categories": ["styles"],
    "cssVars": {
      "light": {
        "success": "oklch(0.62 0.36 145.52)",
        "info": "oklch(0.71 0.45 250)",
        "warning": "oklch(0.73 0.16 72.8)"
      },
      "dark": {
        "success": "oklch(0.62 0.36 145.52)",
        "info": "oklch(0.71 0.45 250)",
        "warning": "oklch(0.73 0.16 72.8)"
      },
      "theme": {
        "color-success": "var(--success)",
        "color-info": "var(--info)",
        "color-warning": "var(--warning)"
      }
    }
  },
  {
    "name": "spinner",
    "type": "registry:ui",
    "title": "Spinner",
    "description": "Tick-based spinner. A redesign of the original shadcn spinner.",
    "categories": ["overrides"],
    "cssVars": {
      "theme": {
        "--animate-tick-fade": "tick-fade 1.2s infinite"
      }
    },
    "css": {
      "@keyframes tick-fade": {
        "from": {
          "opacity": "1"
        },
        "to": {
          "opacity": "0.1"
        }
      }
    }
  },
  {
    "name": "button",
    "type": "registry:ui",
    "title": "Button",
    "description": "Extended button component with extra variants and loading state support.",
    "categories": ["overrides"],
    "dependencies": {
      "base": [
        "@base-ui/react/button",
        "class-variance-authority",
        "clsx",
        "lucide-react",
        "tailwind-merge"
      ],
      "radix": [
        "@radix-ui/react-slot",
        "class-variance-authority",
        "clsx",
        "lucide-react",
        "tailwind-merge"
      ]
    },
    "registryDependencies": ["@uxio/semantic-colors", "spinner"]
  }
]
