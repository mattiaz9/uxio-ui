[
  {
    "name": "spinner",
    "type": "registry:ui",
    "title": "Spinner",
    "description": "Tick-based spinner. A redesign of the original shadcn spinner.",
    "categories": ["overrides"],
    "cssVars": {
      "theme": {
        "--animate-tick-fade": "tick-fade 1.2s infinite"
      }
    },
    "css": {
      "@keyframes tick-fade": {
        "from": {
          "opacity": "1"
        },
        "to": {
          "opacity": "0.1"
        }
      }
    }
  },
  {
    "name": "button",
    "type": "registry:ui",
    "title": "Button",
    "description": "Extended button component with extra variants and loading state support.",
    "categories": ["overrides"],
    "dependencies": {
      "base": [
        "@base-ui/react/button",
        "class-variance-authority",
        "clsx",
        "lucide-react",
        "tailwind-merge"
      ],
      "radix": [
        "@radix-ui/react-slot",
        "class-variance-authority",
        "clsx",
        "lucide-react",
        "tailwind-merge"
      ]
    },
    "registryDependencies": ["spinner"]
  }
]
